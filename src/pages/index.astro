---
import BaseLayout from '../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';
const posts=(await getCollection('blog')).filter((p)=>!p.data.draft).sort((a,b)=>+new Date(b.data.date)-+new Date(a.data.date));
---
<BaseLayout title="눈오지 뷰어">
<h1>눈오지 뷰어</h1>
<p class="muted">쉬운 문체로 운영/자동화/창작 워크플로우를 기록합니다.</p>
{posts.map((post)=>(<article class="card"><h3><a href={`/posts/${post.id}/`}>{post.data.title}</a></h3><p class="muted">{post.data.date}</p>{post.data.summary && <p>{post.data.summary}</p>}</article>))}
</BaseLayout>
