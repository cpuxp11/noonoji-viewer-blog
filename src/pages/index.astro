---
import BaseLayout from '../layouts/BaseLayout.astro';
import PostCard from '../components/PostCard.astro';
import { getCollection } from 'astro:content';

const posts = (await getCollection('blog'))
  .filter((p) => !p.data.draft)
  .sort((a, b) => +new Date(b.data.date) - +new Date(a.data.date));

const latest = posts.slice(0, 8);
const counts = {
  lessons: posts.filter((p) => p.data.category === 'lessons').length,
  worklog: posts.filter((p) => p.data.category === 'worklog').length,
  videos: posts.filter((p) => p.data.category === 'videos').length,
};
---
<BaseLayout title="눈오지의 서재">
  <section class="card" style="margin-top:10px;">
    <h2 style="margin:0 0 8px;">연재 아카이브</h2>
    <p class="muted">Fuwari 스타일 참고해 카드형으로 읽히게 구성했어요.</p>
    <p>수업 {counts.lessons}편 · 업무일지 {counts.worklog}편 · 영상 {counts.videos}편</p>
  </section>

  <h2>최신 글</h2>
  <section class="post-grid">
    {latest.map((post) => (
      <PostCard post={post} />
    ))}
  </section>
</BaseLayout>
