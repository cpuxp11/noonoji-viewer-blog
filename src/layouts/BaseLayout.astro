---
const { title = '눈오지의 서재' } = Astro.props;
---
<html lang="ko">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title}</title>
    <style>
      :root{--fg:#1f2937;--muted:#6b7280;--border:#e5e7eb;--card:#fff;--brand:#2563eb}
      *{box-sizing:border-box}
      body{margin:0;color:var(--fg);line-height:1.78;font-family:-apple-system,BlinkMacSystemFont,'Apple SD Gothic Neo','Noto Sans KR',sans-serif;background:radial-gradient(1200px 420px at 20% -20%, #e0ecff 0%, transparent 55%), #f7fafc}
      .container{max-width:1060px;margin:20px auto;padding:0 16px 40px}
      a{color:var(--brand);text-decoration:none} a:hover{text-decoration:underline}
      .muted{color:var(--muted);font-size:14px}
      header{display:flex;justify-content:space-between;gap:14px;align-items:flex-start;border:1px solid var(--border);border-radius:18px;padding:16px 18px;background:#fff;box-shadow:0 10px 24px rgba(15,23,42,.05);margin-bottom:18px}
      .site-title{margin:0 0 2px;letter-spacing:-.01em}
      .top{display:flex;gap:8px;flex-wrap:wrap;justify-content:flex-end}
      .pill{border:1px solid #dbeafe;border-radius:999px;padding:7px 13px;background:#eff6ff;color:#1e3a8a;font-size:13px;font-weight:700}
      .pill:hover{background:#dbeafe;text-decoration:none}
      .card{border:1px solid var(--border);border-radius:16px;padding:16px;background:var(--card);margin:12px 0}
      .post-grid{display:grid;grid-template-columns:repeat(2,minmax(0,1fr));gap:14px}
      @media (max-width: 760px){header{flex-direction:column}.top{justify-content:flex-start}.post-grid{grid-template-columns:1fr}}
      h1,h2,h3{line-height:1.3}
    </style>
  </head>
  <body>
    <div class="container">
      <header>
        <div>
          <a href="/"><h1 class="site-title">눈오지의 서재</h1></a>
          <div class="muted">운영 로그 · 수업 · 영상 아카이브</div>
        </div>
        <nav class="top">
          <a class="pill" href="/all">전체</a>
          <a class="pill" href="/lessons">수업</a>
          <a class="pill" href="/worklog">업무일지</a>
          <a class="pill" href="/videos">영상</a>
        </nav>
      </header>
      <slot />
    </div>
  </body>
</html>
