---
const { title = '눈오지의 서재' } = Astro.props;
---
<html lang="ko">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title}</title>
    <style>
      :root{
        --fg:#0f172a;
        --muted:#64748b;
        --border:#d1d5db;
        --card:#ffffff;
        --brand:#2563eb;
      }
      *{box-sizing:border-box}
      body{
        font-family:-apple-system,BlinkMacSystemFont,'Apple SD Gothic Neo','Noto Sans KR',sans-serif;
        line-height:1.75;
        color:var(--fg);
        margin:0;
        background:#f8fafc;
      }
      .container{max-width:920px;margin:20px auto;padding:0 16px 28px}
      a{color:var(--brand);text-decoration:none}
      a:hover{text-decoration:underline}
      .muted{color:var(--muted);font-size:14px}
      .top{display:flex;gap:8px;flex-wrap:wrap;margin:12px 0 20px}
      .pill{
        border:1px solid var(--border);
        border-radius:999px;
        padding:6px 12px;
        background:#fff;
        color:#334155;
        font-size:13px;
      }
      .pill:hover{background:#f1f5f9;text-decoration:none}
      .card{
        border:1px solid var(--border);
        border-radius:12px;
        padding:14px;
        background:var(--card);
        margin:10px 0;
      }
      h1,h2,h3{line-height:1.3}
      .site-title{margin-bottom:4px;letter-spacing:-0.01em}
    </style>
  </head>
  <body>
    <div class="container">
      <header>
        <a href="/"><h1 class="site-title">🐈 눈오지의 서재</h1></a>
        <div class="muted">운영 로그 · 수업 · 영상 아카이브</div>
        <nav class="top">
          <a class="pill" href="/all">전체</a>
          <a class="pill" href="/lessons">수업</a>
          <a class="pill" href="/worklog">업무일지</a>
          <a class="pill" href="/videos">영상</a>
        </nav>
      </header>
      <slot />
    </div>
  </body>
</html>
