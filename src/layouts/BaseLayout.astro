---
const { title = '눈오지의 서재' } = Astro.props;
---
<html lang="ko">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title}</title>
    <style>
      :root{
        --fg:#0f172a;
        --muted:#64748b;
        --border:#dbe4f0;
        --card:#ffffffcc;
        --brand:#2563eb;
        --bg1:#f8fbff;
        --bg2:#eef6ff;
      }
      *{box-sizing:border-box}
      body{
        font-family:-apple-system,BlinkMacSystemFont,'Apple SD Gothic Neo','Noto Sans KR',sans-serif;
        line-height:1.75;
        color:var(--fg);
        margin:0;
        background:
          radial-gradient(900px 400px at 10% -10%, #dbeafe 0%, transparent 60%),
          radial-gradient(700px 360px at 110% 0%, #e0e7ff 0%, transparent 58%),
          linear-gradient(180deg, var(--bg1), var(--bg2));
      }
      .container{max-width:980px;margin:22px auto;padding:0 16px 28px}
      a{color:var(--brand);text-decoration:none}
      a:hover{text-decoration:underline}
      .muted{color:var(--muted);font-size:14px}
      .top{display:flex;gap:10px;flex-wrap:wrap;margin:12px 0 20px}
      .pill{
        border:1px solid var(--border);
        border-radius:999px;
        padding:7px 13px;
        background:#fff;
        color:#334155;
        font-size:14px;
        transition:all .15s ease;
      }
      .pill:hover{background:#eff6ff;border-color:#bfdbfe;text-decoration:none}
      .card{
        border:1px solid var(--border);
        border-radius:16px;
        padding:16px;
        background:var(--card);
        backdrop-filter: blur(6px);
        margin:12px 0;
        box-shadow:0 6px 18px rgba(15,23,42,.04);
      }
      h1,h2,h3{line-height:1.3}
      .site-title{margin-bottom:4px;letter-spacing:-0.02em}
    </style>
  </head>
  <body>
    <div class="container">
      <header>
        <a href="/"><h1 class="site-title">🐈 눈오지의 서재</h1></a>
        <div class="muted">운영 로그 · 수업 · 영상 아카이브</div>
        <nav class="top">
          <a class="pill" href="/all">전체</a>
          <a class="pill" href="/lessons">수업</a>
          <a class="pill" href="/worklog">업무일지</a>
          <a class="pill" href="/videos">영상</a>
        </nav>
      </header>
      <slot />
    </div>
  </body>
</html>
