---
const { title = '눈오지의 서재' } = Astro.props;
---
<html lang="ko">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title}</title>
    <style>
      :root{
        --fg:#111827;
        --muted:#6b7280;
        --border:#e5e7eb;
        --card:#ffffff;
        --brand:#2563eb;
        --bg:#f8fafc;
      }
      *{box-sizing:border-box}
      body{
        margin:0;
        color:var(--fg);
        line-height:1.8;
        font-family:-apple-system,BlinkMacSystemFont,'Apple SD Gothic Neo','Noto Sans KR',sans-serif;
        background:
          radial-gradient(1200px 300px at 50% -15%, #dbeafe 0%, transparent 65%),
          var(--bg);
      }
      a{color:var(--brand);text-decoration:none}
      a:hover{text-decoration:underline}
      .muted{color:var(--muted);font-size:14px}
      .container{max-width:1040px;margin:20px auto;padding:0 16px 40px}

      .topbar{
        border:1px solid var(--border);
        border-radius:18px;
        background:#fff;
        box-shadow:0 12px 24px rgba(15,23,42,.05);
        padding:16px;
        margin-bottom:16px;
      }
      .topbar-head{display:flex;justify-content:space-between;gap:12px;align-items:flex-start}
      .brand{margin:0 0 2px;letter-spacing:-0.02em;font-size:30px}
      .brand-sub{margin:0}
      .topnav{display:flex;gap:8px;flex-wrap:wrap}
      .pill{
        border:1px solid #dbeafe;
        border-radius:999px;
        padding:7px 12px;
        background:#eff6ff;
        color:#1e3a8a;
        font-size:13px;
        font-weight:700;
      }
      .pill:hover{background:#dbeafe;text-decoration:none}

      .card{
        border:1px solid var(--border);
        border-radius:16px;
        padding:16px;
        background:var(--card);
        margin:12px 0;
        box-shadow:0 6px 16px rgba(15,23,42,.04);
      }
      .post-grid{display:grid;grid-template-columns:repeat(2,minmax(0,1fr));gap:14px}
      h1,h2,h3{line-height:1.3}

      .prose{font-size:17px}
      .prose p{margin:0 0 14px}
      .prose h2{margin:26px 0 10px}
      .prose h3{margin:20px 0 8px}
      .prose ul,.prose ol{margin:8px 0 16px 22px}
      .prose img{width:100%;height:auto;border-radius:12px;border:1px solid var(--border)}

      @media (max-width: 760px){
        .topbar-head{flex-direction:column}
        .post-grid{grid-template-columns:1fr}
        .brand{font-size:26px}
      }
    </style>
  </head>
  <body>
    <div class="container">
      <header class="topbar">
        <div class="topbar-head">
          <div>
            <a href="/"><h1 class="brand">눈오지의 서재</h1></a>
            <p class="muted brand-sub">운영 로그 · 수업 · 영상 아카이브</p>
          </div>
          <nav class="topnav">
            <a class="pill" href="/all">전체</a>
            <a class="pill" href="/lessons">수업</a>
            <a class="pill" href="/worklog">업무일지</a>
            <a class="pill" href="/videos">영상</a>
          </nav>
        </div>
      </header>
      <main>
        <slot />
      </main>
    </div>
  </body>
</html>
