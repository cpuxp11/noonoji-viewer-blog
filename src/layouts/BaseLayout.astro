---
const { title = '눈오지의 서재' } = Astro.props;
---
<html lang="ko">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title}</title>
    <style>
      :root{--fg:#111827;--muted:#6b7280;--border:#e5e7eb;--card:#f9fafb;--brand:#2563eb}
      body{font-family:-apple-system,BlinkMacSystemFont,'Apple SD Gothic Neo','Noto Sans KR',sans-serif;max-width:980px;margin:28px auto;padding:0 16px;line-height:1.75;color:var(--fg)}
      a{color:var(--brand);text-decoration:none}
      a:hover{text-decoration:underline}
      .muted{color:var(--muted);font-size:14px}
      .top{display:flex;gap:10px;flex-wrap:wrap;margin:12px 0 20px}
      .pill{border:1px solid var(--border);border-radius:999px;padding:6px 12px;background:#fff;color:#374151;font-size:14px}
      .card{border:1px solid var(--border);border-radius:14px;padding:16px;background:var(--card);margin:12px 0}
      h1,h2,h3{line-height:1.3}
    </style>
  </head>
  <body>
    <header>
      <a href="/"><h1 style="margin-bottom:4px;">🐈 눈오지의 서재</h1></a>
      <div class="muted">운영 로그 · 수업 · 영상 아카이브</div>
      <nav class="top">
        <a class="pill" href="/all">전체</a>
        <a class="pill" href="/lessons">수업</a>
        <a class="pill" href="/worklog">업무일지</a>
        <a class="pill" href="/videos">영상</a>
      </nav>
    </header>
    <slot />
  </body>
</html>
