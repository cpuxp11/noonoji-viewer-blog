---
import CategoryBadge from './CategoryBadge.astro';
const { post } = Astro.props;
---
<article class="card post-card">
  <div class="row">
    <CategoryBadge category={post.data.category} />
    <span class="muted">{post.data.date}</span>
  </div>
  <h3><a href={`/posts/${post.id}/`}>{post.data.title}</a></h3>
  {post.data.summary && <p>{post.data.summary}</p>}
</article>

<style>
.post-card{transition:transform .14s ease, box-shadow .14s ease}
.post-card:hover{transform:translateY(-1px); box-shadow:0 8px 18px rgba(15,23,42,.06)}
.row{display:flex;justify-content:space-between;align-items:center;gap:10px}
h3{margin:10px 0 6px;letter-spacing:-0.01em}
p{margin:0;color:#374151}
</style>
